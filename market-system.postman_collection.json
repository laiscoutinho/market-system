{
  "info": {
    "name": "Market System API",
    "description": "Collection completa da API de gestão de supermercado",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuário ADMIN",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Sistema\",\n  \"email\": \"admin@market.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Registrar usuário VENDEDOR",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Vendedora\",\n  \"email\": \"maria@market.com\",\n  \"password\": \"maria123\",\n  \"role\": \"VENDEDOR\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@market.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Criar categoria - Grãos e Cereais",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grãos e Cereais\"\n}"
            }
          }
        },
        {
          "name": "Criar categoria - Laticínios",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laticínios\"\n}"
            }
          }
        },
        {
          "name": "Criar categoria - Bebidas",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bebidas\"\n}"
            }
          }
        },
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Criar produto - Arroz Integral 5kg",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arroz Integral 5kg\",\n  \"price\": 18.90,\n  \"stock\": 50,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Criar produto - Feijão Carioca 1kg",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Feijão Carioca 1kg\",\n  \"price\": 7.50,\n  \"stock\": 80,\n  \"categoryId\": 1\n}"
            }
          }
        },
        {
          "name": "Criar produto - Leite Integral 1L",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Leite Integral 1L\",\n  \"price\": 4.99,\n  \"stock\": 100,\n  \"categoryId\": 2\n}"
            }
          }
        },
        {
          "name": "Criar produto - Queijo Mussarela 500g",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Queijo Mussarela 500g\",\n  \"price\": 19.90,\n  \"stock\": 30,\n  \"categoryId\": 2\n}"
            }
          }
        },
        {
          "name": "Criar produto - Suco de Laranja 1L",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suco de Laranja 1L\",\n  \"price\": 8.90,\n  \"stock\": 60,\n  \"categoryId\": 3\n}"
            }
          }
        },
        {
          "name": "Criar produto - Refrigerante Cola 2L",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Refrigerante Cola 2L\",\n  \"price\": 6.50,\n  \"stock\": 40,\n  \"categoryId\": 3\n}"
            }
          }
        },
        {
          "name": "Listar produtos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/products/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arroz Integral 5kg Premium\",\n  \"price\": 21.90,\n  \"stock\": 45\n}"
            }
          }
        },
        {
          "name": "Remover produto",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/6",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Registrar venda",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sales",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2 },\n    { \"productId\": 3, \"quantity\": 3 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Registrar venda - estoque insuficiente (erro esperado)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/sales",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 9999 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar vendas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sales",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Relatório por período",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sales/report?startDate=2025-01-01&endDate=2025-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "report"],
              "query": [
                { "key": "startDate", "value": "2025-01-01" },
                { "key": "endDate", "value": "2025-12-31" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}